# ═══════════════════════════════════════════════
#   Student Bug Tracker — Backend Environment
#   Copy this file to .env and fill in values
# ═══════════════════════════════════════════════

# ─── Database ───
# Supabase PostgreSQL (recommended — free, never expires, has UI)
# Get from: supabase.com → your project → Settings → Database → URI
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Local PostgreSQL alternative:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/student_bug_tracker"

# ─── JWT Authentication ───
# Use a long random string — never share this
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ─── Server ───
PORT=5000
NODE_ENV="development"

# ─── Frontend URL (for CORS + email links) ───
# Local:      http://localhost:3000
# Production: https://bug-tracker-ui-evqv.onrender.com
FRONTEND_URL="http://localhost:3000"

# ─── Email (Gmail SMTP) ───
# 1. Enable 2-Step Verification: myaccount.google.com/security
# 2. Generate App Password: myaccount.google.com/apppasswords
# 3. Paste the 16-char password below (no spaces)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="BugTracker <your-gmail@gmail.com>"
